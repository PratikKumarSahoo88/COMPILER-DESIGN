parser.y (Bison File)

Save as: parser.y

%{

#include<stdio.h>

#include<stdlib.h>



int yylex();

void yyerror(const char *s);

%}



%token NUM ID IF ELSE WHILE



%left '+' '-'

%left '*' '/'



%%



stmt:

        expr '\n'{ printf("Valid Expression\n"); }

      | IF '(' expr ')' stmt ELSE stmt

      | WHILE '(' expr ')' stmt

      ;



expr:

        expr '+' expr

      | expr '-' expr

      | expr '*' expr

      | expr '/' expr

      | '(' expr ')'

      | NUM

      | ID

      ;



%%



void yyerror(const char *s)

{

    printf("Syntax Error\n");

}



int main()

{

    printf("Enter input:\n");

    return yyparse();

}





lexer.l (Flex File)

Save as: lexer.l

%{

#include "parser.tab.h"

%}



%%



"if"        { return IF; }

"else"      { return ELSE; }

"while"     { return WHILE; }



[0-9]+      { return NUM; }

[a-zA-Z_][a-zA-Z0-9_]*  { return ID; }



"+"         { return '+'; }

"-"         { return '-'; }

"*"         { return '*'; }

"/"         { return '/'; }

"("         { return '('; }

")"         { return ')'; }



[ \t]       ;        /* Ignore spaces and tabs */

\n          { return '\n'; }



.           { return yytext[0]; }



%%



int yywrap()

{

    return 1;

}
